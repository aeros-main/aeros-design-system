{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Aeros Design Tokens",
    "version": "1.0.0"
  },
  "color": {
    "royal": {
      "50":  { "$value": "#EEF1FD", "$type": "color" },
      "100": { "$value": "#C5CEFA", "$type": "color" },
      "200": { "$value": "#9DAAED", "$type": "color" },
      "400": { "$value": "#5B78E8", "$type": "color" },
      "600": { "$value": "#2347D9", "$type": "color" },
      "800": { "$value": "#1A2F8A", "$type": "color" },
      "900": { "$value": "#0B1B6B", "$type": "color" }
    },
    "ink": {
      "50":  { "$value": "#F5F5F5", "$type": "color" },
      "100": { "$value": "#E5E5E5", "$type": "color" },
      "200": { "$value": "#C2C2C2", "$type": "color" },
      "400": { "$value": "#737373", "$type": "color" },
      "600": { "$value": "#404040", "$type": "color" },
      "800": { "$value": "#1A1A1A", "$type": "color" },
      "900": { "$value": "#0A0A0A", "$type": "color" }
    },
    "slate": {
      "50":  { "$value": "#F5F6FA", "$type": "color" },
      "100": { "$value": "#E2E5F0", "$type": "color" },
      "200": { "$value": "#BCC2D8", "$type": "color" },
      "400": { "$value": "#7A85A8", "$type": "color" },
      "600": { "$value": "#4A5278", "$type": "color" },
      "800": { "$value": "#1E2540", "$type": "color" },
      "900": { "$value": "#0A0F2E", "$type": "color" }
    },
    "semantic": {
      "success":      { "$value": "#16A34A", "$type": "color" },
      "success-bg":   { "$value": "#DCFCE7", "$type": "color" },
      "success-text": { "$value": "#15803D", "$type": "color" },
      "success-border": { "$value": "#BBF7D0", "$type": "color" },
      "warning":      { "$value": "#D97706", "$type": "color" },
      "warning-bg":   { "$value": "#FEF3C7", "$type": "color" },
      "warning-text": { "$value": "#B45309", "$type": "color" },
      "warning-border": { "$value": "#FDE68A", "$type": "color" },
      "danger":       { "$value": "#DC2626", "$type": "color" },
      "danger-bg":    { "$value": "#FEE2E2", "$type": "color" },
      "danger-text":  { "$value": "#B91C1C", "$type": "color" },
      "danger-border": { "$value": "#FECACA", "$type": "color" },
      "info":         { "$value": "#2347D9", "$type": "color" },
      "info-bg":      { "$value": "#EEF1FD", "$type": "color" },
      "info-text":    { "$value": "#1A2F8A", "$type": "color" },
      "info-border":  { "$value": "#C5CEFA", "$type": "color" }
    }
  },
  "alias": {
    "light": {
      "bg-canvas":        "#FFFFFF",
      "bg-surface":       "#FFFFFF",
      "bg-subtle":        "#F5F5F5",
      "bg-inverse":       "#0A0A0A",
      "fg-primary":       "#0A0A0A",
      "fg-secondary":     "#404040",
      "fg-muted":         "#6B6B6B",
      "fg-inverse":       "#FFFFFF",
      "fg-brand":         "#0A0A0A",
      "border-default":   "#E5E5E5",
      "border-strong":    "#C2C2C2",
      "border-focus":     "#0A0A0A",
      "brand-primary":    "#0A0A0A",
      "brand-primary-hover": "#404040",
      "brand-primary-muted": "#F5F5F5",
      "accent":           "#2347D9",
      "accent-muted":     "#EEF1FD",
      "focus-ring":       "#E5E5E5"
    },
    "dark": {
      "bg-canvas":        "#0A0A0A",
      "bg-surface":       "#0A0A0A",
      "bg-subtle":        "#1A1A1A",
      "bg-inverse":       "#FFFFFF",
      "fg-primary":       "#FFFFFF",
      "fg-secondary":     "#E5E5E5",
      "fg-muted":         "#8C8C8C",
      "fg-inverse":       "#0A0A0A",
      "fg-brand":         "#FFFFFF",
      "border-default":   "#1A1A1A",
      "border-strong":    "#404040",
      "border-focus":     "#FFFFFF",
      "brand-primary":    "#FFFFFF",
      "brand-primary-hover": "#E5E5E5",
      "brand-primary-muted": "#1A1A1A",
      "accent":           "#5B78E8",
      "accent-muted":     "#1A2F8A",
      "focus-ring":       "#1A1A1A"
    }
  },
  "font": {
    "family": {
      "sans": "'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif",
      "mono": "'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
      "logo": "'Nunito Sans', 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif"
    },
    "weight": {
      "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800
    }
  },
  "text": {
    "display-xl": { "size": 56, "weight": 800, "lineHeight": 1.0, "tracking": "-0.04em" },
    "display-lg": { "size": 42, "weight": 800, "lineHeight": 1.0, "tracking": "-0.04em" },
    "display-md": { "size": 32, "weight": 800, "lineHeight": 1.05, "tracking": "-0.03em" },
    "h1":         { "size": 28, "weight": 800, "lineHeight": 1.1,  "tracking": "-0.03em" },
    "h2":         { "size": 22, "weight": 800, "lineHeight": 1.15, "tracking": "-0.02em" },
    "h3":         { "size": 20, "weight": 700, "lineHeight": 1.2,  "tracking": "-0.02em" },
    "h4":         { "size": 16, "weight": 700, "lineHeight": 1.3,  "tracking": "-0.01em" },
    "body-lg":    { "size": 16, "weight": 500, "lineHeight": 1.5,  "tracking": "0" },
    "body-md":    { "size": 14, "weight": 500, "lineHeight": 1.55, "tracking": "0" },
    "body-sm":    { "size": 13, "weight": 500, "lineHeight": 1.55, "tracking": "0" },
    "caption":    { "size": 12, "weight": 500, "lineHeight": 1.5,  "tracking": "0" },
    "overline":   { "size": 11, "weight": 600, "lineHeight": 1.3,  "tracking": "0.08em", "transform": "uppercase" },
    "mono-lg":    { "size": 22, "weight": 500, "lineHeight": 1.2,  "tracking": "-0.01em", "family": "mono" },
    "mono-md":    { "size": 14, "weight": 500, "lineHeight": 1.5,  "tracking": "0",       "family": "mono" },
    "mono-sm":    { "size": 12, "weight": 400, "lineHeight": 1.5,  "tracking": "0",       "family": "mono" },
    "mono-xs":    { "size": 11, "weight": 400, "lineHeight": 1.5,  "tracking": "0",       "family": "mono" }
  },
  "space": {
    "0": 0, "px": 1, "0.5": 2, "1": 4, "1.5": 6, "2": 8, "2.5": 10, "3": 12, "3.5": 14,
    "4": 16, "5": 20, "6": 24, "7": 28, "8": 32, "10": 40, "12": 48, "14": 56,
    "16": 64, "20": 80, "24": 96, "32": 128
  },
  "radius": {
    "none": 0, "sm": 6, "md": 8, "lg": 12, "xl": 16, "2xl": 20, "3xl": 24, "4xl": 32, "full": 9999
  },
  "shadow": {
    "xs":   "0 1px 2px rgba(10,15,46,0.05)",
    "sm":   "0 1px 3px rgba(10,15,46,0.07), 0 0 0 1px rgba(226,229,240,0.8)",
    "md":   "0 4px 12px rgba(10,15,46,0.08)",
    "lg":   "0 4px 16px rgba(10,15,46,0.10)",
    "xl":   "0 20px 40px rgba(10,15,46,0.20)",
    "focus": "0 0 0 3px rgba(91,120,232,0.25)",
    "focus-danger": "0 0 0 3px rgba(220,38,38,0.20)"
  },
  "motion": {
    "duration": { "fast": 120, "base": 200, "slow": 320 },
    "ease": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.3, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)"
    }
  },
  "z": {
    "base": 0, "dropdown": 1000, "sticky": 1100, "overlay": 1300,
    "modal": 1400, "popover": 1500, "toast": 1600, "tooltip": 1700
  },
  "breakpoint": {
    "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "2xl": 1536
  }
}
